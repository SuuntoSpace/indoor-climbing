{
  "name": "Indoor Climbing",
  "version": "1.0",
  "author": "Oscar Muñoz Ferriz",
  "description": "Attempts,Time,VSpeed,Recovery",
  "type": "feature",
  "usage": "workout",
  "modificationTime": 1674690409, 
  "in": [
    {
      "name": "DurationAscent",
      "source": "/Fusion/Altitude/AscentTime",
      "type": "subscribe"
    },
    {
      "name": "DurationDescent",
      "source": "/Fusion/Altitude/DescentTime",
      "type": "subscribe"
    },
    {
      "name": "AscentMeters",
      "source": "/Fusion/Altitude/Ascent",
      "type": "subscribe"
    },
    {
      "name": "DescentMeters",
      "source": "/Fusion/Altitude/Descent",
      "type": "subscribe"
    },

    {
      "name": "VerticalSpeed",
      "source": "/Fusion/Altitude/VerticalSpeed",
      "type": "subscribe"
    }
  ],
  "out": [
    {
      "name": "climbAttempts"
    },
    {
      "name": "climbAttemptAscent"
    },
    {
      "name": "climbDurationAscent",
      "log": true,
      "shownName": "Duration Ascent",
      "format": "Duration_Fourdigits"     
    },
    {
      "name": "climbDurationAscentDescent",
      "log": true,
      "shownName": "Duration Ascent Descent",
      "format": "Duration_Fourdigits"
    },
    {
      "name": "climbVerticalSpeed",
      "log": true,
      "shownName": "Vertical Speed",
      "format": "Count_Threedigits"
    },
    {
      "name": "isClimbing",
      "format": "Count_Threedigits"
    },
    {
      "name": "recommendedRest",
      "format": "Duration_Fourdigits"
    }
  ],
  "template": [
    { "name": "t.html" }
  ]
}